{
  "mcpServers": {
    "newrelic": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "--package",
        "@kavinga/commerce-tools",
        "newrelic-mcp"
      ],
      "env": {
        "NEW_RELIC_API_KEY": "${NEW_RELIC_API_KEY}",
        "NEW_RELIC_REGION": "${NEW_RELIC_REGION:-us}"
      }
    },
    "jira": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "--package",
        "@kavinga/commerce-tools",
        "jira-mcp"
      ],
      "env": {
        "JIRA_BASE_URL": "${JIRA_BASE_URL}",
        "JIRA_EMAIL": "${JIRA_EMAIL}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
      }
    }
  }
}
